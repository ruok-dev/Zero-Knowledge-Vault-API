generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  salt         String   // Server-side salt for Argon2 (client-side)
  authKeyHash  String   // Hash of the derived Auth Key
  vaultItems   VaultItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VaultItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String   // Encrypted
  data      String   // Encrypted blob (AES-GCM)
  nonce     String   // IV/Nonce for AES-GCM
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
